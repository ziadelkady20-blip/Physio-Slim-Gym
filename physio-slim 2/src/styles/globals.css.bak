/* ═══════════════════════════════════════════════════
   PHYSIO SLIM — Global Styles
   Black & Gold Luxury Theme
   ═══════════════════════════════════════════════════ */

@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --bg: #050505;
  --surface: #0D0D0D;
  --card: #111111;
  --gold: #D4AF37;
  --gold2: #C9A227;
  --gold-light: #E0C35A;
  --white: #FFFFFF;
  --gray: #A0A0A0;
  --border: rgba(212, 175, 55, 0.18);
  --glass: rgba(13, 13, 13, 0.72);
  --radius: 0px;

  /* Shadcn tokens */
  --background: 0 0% 2%;
  --foreground: 0 0% 100%;
  --card: 0 0% 5%;
  --card-foreground: 0 0% 100%;
  --primary: 45 65% 52%;
  --primary-foreground: 0 0% 0%;
  --secondary: 0 0% 7%;
  --secondary-foreground: 0 0% 100%;
  --muted: 0 0% 10%;
  --muted-foreground: 0 0% 63%;
  --accent: 0 0% 10%;
  --accent-foreground: 0 0% 100%;
  --destructive: 0 72% 51%;
  --destructive-foreground: 0 0% 100%;
  --border: 45 65% 52% / 0.18;
  --input: 45 65% 52% / 0.12;
  --ring: 45 65% 52%;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  background: var(--bg);
  color: var(--white);
  font-family: 'Inter', sans-serif;
  overflow-x: hidden;
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-track {
  background: var(--bg);
}
::-webkit-scrollbar-thumb {
  background: rgba(212, 175, 55, 0.3);
  border-radius: 0;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--gold);
}

/* ── SELECTION ── */
::selection {
  background: rgba(212, 175, 55, 0.25);
  color: var(--white);
}

/* ── GOLD GRADIENT TEXT ── */
.text-gold-gradient {
  background: linear-gradient(135deg, var(--gold), var(--gold2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ── CLIP PATH BUTTON ── */
.clip-btn {
  clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
}

.clip-btn-sm {
  clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
}

/* ── GOLD BORDER ── */
.border-gold {
  border-color: var(--gold);
}

/* ── GLASS CARD ── */
.glass-card {
  background: var(--glass);
  backdrop-filter: blur(20px);
  border: 1px solid var(--border);
}

/* ── SECTION BASE ── */
.section-base {
  padding: 110px 40px;
}

/* ── SCROLL PROGRESS BAR ── */
#scroll-bar {
  position: fixed;
  top: 0;
  left: 0;
  height: 3px;
  width: 0%;
  background: linear-gradient(90deg, var(--gold), var(--gold2));
  z-index: 9999;
  transition: width 0.1s linear;
}

/* ── ANIMATIONS ── */
@keyframes heroZoom {
  from { transform: scale(1.05); }
  to { transform: scale(1.12); }
}

@keyframes glowPulse {
  0%, 100% { opacity: 0.6; transform: translate(-50%, -60%) scale(1); }
  50% { opacity: 1; transform: translate(-50%, -60%) scale(1.1); }
}

@keyframes heroEnter {
  from { opacity: 0; transform: translateY(40px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

@keyframes scrollDot {
  0%, 100% { transform: translateY(0); opacity: 1; }
  50% { transform: translateY(6px); opacity: 0.3; }
}

@keyframes waBounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.06); }
}

@keyframes slide {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}

@keyframes loaderPulse {
  0%, 100% { transform: scale(1); filter: drop-shadow(0 0 12px rgba(212,175,55,0.5)); }
  50% { transform: scale(1.08); filter: drop-shadow(0 0 28px rgba(212,175,55,0.9)); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes shimmer {
  0% { background-position: -200px 0; }
  100% { background-position: calc(200px + 100%) 0; }
}

/* ── REVEAL ── */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.left { transform: translateX(-50px); }
.reveal.right { transform: translateX(50px); }
.reveal.visible { opacity: 1; transform: none; }

/* ── LOADING SKELETON ── */
.skeleton {
  background: linear-gradient(90deg, var(--surface) 25%, rgba(212,175,55,0.05) 50%, var(--surface) 75%);
  background-size: 200px 100%;
  animation: shimmer 1.5s infinite;
}

/* ── ADMIN SPECIFIC ── */
.admin-sidebar-active {
  background: rgba(212, 175, 55, 0.1);
  border-left: 2px solid var(--gold);
  color: var(--gold);
}

/* ── TOAST CONTAINER ── */
.toast-container {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ── FORM STYLES ── */
.form-input {
  width: 100%;
  background: rgba(212, 175, 55, 0.04);
  border: 1px solid rgba(212, 175, 55, 0.18);
  color: #fff;
  padding: 12px 16px;
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  transition: border-color 0.3s;
  outline: none;
}

.form-input:focus {
  border-color: var(--gold);
  background: rgba(212, 175, 55, 0.07);
}

.form-input::placeholder {
  color: rgba(160, 160, 160, 0.5);
}

.form-label {
  display: block;
  font-size: 11px;
  letter-spacing: 2px;
  color: var(--gold);
  font-family: 'Montserrat', sans-serif;
  font-weight: 700;
  text-transform: uppercase;
  margin-bottom: 8px;
}

/* Responsive */
@media (max-width: 768px) {
  .section-base {
    padding: 70px 20px;
  }
}
