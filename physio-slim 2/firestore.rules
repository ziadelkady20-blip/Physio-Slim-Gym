// ═══════════════════════════════════════════════════
// PHYSIO SLIM — Firebase Security Rules
// Deploy: firebase deploy --only firestore:rules
// ═══════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() &&
        getUserData().role in ['admin', 'super_admin'];
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        getUserData().role == 'super_admin';
    }

    function isManager() {
      return isSignedIn() &&
        getUserData().role in ['manager', 'admin', 'super_admin'];
    }

    // ── PUBLIC READ COLLECTIONS ───────────────────
    // These are read by the website frontend (unauthenticated)

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /memberships/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /facilities/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /trainers/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /offers/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── PRIVATE / ADMIN-ONLY COLLECTIONS ──────────

    match /leads/{doc} {
      // Anyone can CREATE a lead (contact form)
      allow create: if true;
      // Only admins/managers can read and update
      allow read, update, delete: if isManager();
    }

    match /notifications/{doc} {
      allow read: if isManager();
      allow create: if true; // Can be created by server functions or contact form
      allow update, delete: if isAdmin();
    }

    match /analytics/{doc} {
      // Allow tracking events from public (increment-only)
      allow create, update: if true;
      allow read: if isManager();
      allow delete: if isSuperAdmin();
    }

    match /media/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{uid} {
      // Users can read and update their own document
      allow read: if isSignedIn() && (request.auth.uid == uid || isManager());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSuperAdmin() || (isSignedIn() && request.auth.uid == uid &&
        // Regular users can only update non-role fields
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isSuperAdmin();
    }
  }
}
