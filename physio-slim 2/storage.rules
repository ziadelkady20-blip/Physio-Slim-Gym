// ═══════════════════════════════════════════════════
// PHYSIO SLIM — Firebase Storage Rules
// Deploy: firebase deploy --only storage
// ═══════════════════════════════════════════════════

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn();
      // In production, add Firestore role check via custom claims:
      // return isSignedIn() && request.auth.token.role in ['admin', 'super_admin'];
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    function isValidVideo() {
      return request.resource.contentType.matches('video/.*')
        && request.resource.size < 100 * 1024 * 1024; // 100MB limit
    }

    // ── PUBLIC READ ───────────────────────────────
    // All uploaded files are publicly readable (CDN)
    match /{allPaths=**} {
      allow read: if true;
    }

    // ── ADMIN WRITE ───────────────────────────────
    match /hero/{file} {
      allow write: if isAdmin() && (isValidImage() || isValidVideo());
    }

    match /gallery/{file} {
      allow write: if isAdmin() && isValidImage();
    }

    match /facilities/{file} {
      allow write: if isAdmin() && isValidImage();
    }

    match /trainers/{file} {
      allow write: if isAdmin() && isValidImage();
    }

    match /about/{file} {
      allow write: if isAdmin() && isValidImage();
    }

    match /media/{file} {
      allow write: if isAdmin() && isValidImage();
    }

    match /logos/{file} {
      allow write: if isAdmin() && isValidImage();
    }

    match /offers/{file} {
      allow write: if isAdmin() && isValidImage();
    }

    match /testimonials/{file} {
      allow write: if isAdmin() && isValidImage();
    }

    match /seo/{file} {
      allow write: if isAdmin() && isValidImage();
    }
  }
}
